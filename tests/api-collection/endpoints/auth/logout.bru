meta {
  name: Logout
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
}

tests {
  test("Status is 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("Logout successful", function() {
    expect(res.body.message).to.be.a('string');
  });
}
