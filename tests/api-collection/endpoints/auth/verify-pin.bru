meta {
  name: Verify PIN
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/pin/verify
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "pin": "123456"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("Status is 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("PIN verification successful", function() {
    expect(res.body.message).to.include('verified');
  });
}
