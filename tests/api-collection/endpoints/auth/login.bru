meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{testEmail}}",
    "password": "{{testPassword}}"
  }
}

vars:post-response {
  authToken: res.body.data.token
}

assert {
  res.status: eq 200
  res.body.data.token: isString
  res.body.data.user.email: isString
}

tests {
  test("Status is 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("Response contains JWT token", function() {
    expect(res.body.data.token).to.be.a('string');
    expect(res.body.data.token.length).to.be.greaterThan(50);
  });

  test("Token appears to be JWT format", function() {
    const token = res.body.data.token;
    const parts = token.split('.');
    expect(parts.length).to.equal(3);
  });

  test("Response contains user info", function() {
    expect(res.body.data.user).to.have.property('id');
    expect(res.body.data.user).to.have.property('email');
    expect(res.body.data.user).to.have.property('azureTag');
  });
}
