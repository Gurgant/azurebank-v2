meta {
  name: Transfer to User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/transfers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "fromAccountId": "{{accountId}}",
    "recipientAzureTag": "recipient.user",
    "amount": 50.00,
    "description": "Test transfer"
  }
}

assert {
  res.status: in [201, 400, 404]
}

tests {
  test("Status is valid response", function() {
    // 201 = success, 400 = validation error, 404 = recipient not found
    expect([201, 400, 404]).to.include(res.status);
  });

  test("Response contains expected properties on success", function() {
    if (res.status === 201) {
      expect(res.body.data).to.have.property('transactionNumber');
      expect(res.body.data).to.have.property('amount');
      expect(res.body.data).to.have.property('newBalance');
      expect(res.body.data).to.have.property('recipientAzureTag');
    }
  });
}
