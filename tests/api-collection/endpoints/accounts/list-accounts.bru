meta {
  name: List Accounts
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/accounts
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

vars:post-response {
  accountId: res.body.data[0].id
}

assert {
  res.status: eq 200
  res.body.data: isArray
}

tests {
  test("Status is 200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("Response contains accounts array", function() {
    expect(res.body.data).to.be.an('array');
  });

  test("At least one account exists (primary)", function() {
    expect(res.body.data.length).to.be.greaterThanOrEqual(1);
  });

  test("Account has required properties", function() {
    const account = res.body.data[0];
    expect(account).to.have.property('id');
    expect(account).to.have.property('accountNumber');
    expect(account).to.have.property('name');
    expect(account).to.have.property('type');
    expect(account).to.have.property('balance');
    expect(account).to.have.property('isPrimary');
  });
}
