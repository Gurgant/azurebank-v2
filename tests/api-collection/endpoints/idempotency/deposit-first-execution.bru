meta {
  name: Idempotency 1 - Deposit (first execution)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/transactions/deposit
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Content-Type: application/json
  Idempotency-Key: {{idemScenarioKey}}
}

script:pre-request {
  // One key for the whole replay scenario (requests 1-3 in this folder)
  const { randomUUID } = require('crypto');
  bru.setVar('idemScenarioKey', randomUUID());
}

body:json {
  {
    "accountId": "{{accountId}}",
    "amount": 12.34,
    "description": "Idempotency scenario"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("First execution is 201 Created", function() {
    expect(res.status).to.equal(201);
  });

  test("First execution is NOT a replay", function() {
    expect(res.headers['idempotency-replayed']).to.be.undefined;
  });

  test("Remember the original response body", function() {
    bru.setVar('idemScenarioBody', JSON.stringify(res.body));
  });
}
