meta {
  name: Idempotency 4 - Missing header (400)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/transactions/deposit
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "accountId": "{{accountId}}",
    "amount": 5.00,
    "description": "No idempotency key"
  }
}

assert {
  res.status: eq 400
  res.body.errorCode: eq IDEMPOTENCY_KEY_MISSING
}

tests {
  test("Monetary operations without Idempotency-Key are rejected", function() {
    expect(res.status).to.equal(400);
  });

  test("ProblemDetails carries the dedicated errorCode", function() {
    expect(res.body.errorCode).to.equal('IDEMPOTENCY_KEY_MISSING');
  });
}
