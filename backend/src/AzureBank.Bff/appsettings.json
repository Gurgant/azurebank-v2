{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "AllowedHosts": "*",

  "Session": {
    "CookieName": ".AzureBank.Session",
    "InactivityTimeoutMinutes": 30,
    "AbsoluteTimeoutMinutes": 60
  },

  "Security": {
    "PinValidityMinutes": 5,
    "MaxPinAttempts": 3,
    "LockoutMinutes": 15
  },

  "RateLimiting": {
    "GlobalPermitLimit": 300,
    "GlobalWindowSeconds": 60,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60
  },

  "ForwardedHeaders": {
    "_comment": "Deployments behind a proxy/LB MUST list the proxy IPs here so the rate limiter partitions on the real client IP. Empty = the BFF is the edge; X-Forwarded-For is ignored (never trusted from untrusted sources). See ADR-0013.",
    "KnownProxies": [],
    "ForwardLimit": 1
  },

  "ReverseProxy": {
    "Routes": {
      "api-auth-login-route": {
        "ClusterId": "backend-api",
        "RateLimiterPolicy": "auth",
        "Match": { "Path": "/api/auth/login" },
        "Transforms": [ { "PathRemovePrefix": "" } ]
      },
      "api-auth-register-route": {
        "ClusterId": "backend-api",
        "RateLimiterPolicy": "auth",
        "Match": { "Path": "/api/auth/register" },
        "Transforms": [ { "PathRemovePrefix": "" } ]
      },
      "api-route": {
        "ClusterId": "backend-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "" }
        ]
      }
    },
    "Clusters": {
      "backend-api": {
        "Destinations": {
          "primary": {
            "Address": "https://localhost:7215"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      }
    }
  },

  "BackendApi": {
    "BaseUrl": "https://localhost:7215"
  }
}
